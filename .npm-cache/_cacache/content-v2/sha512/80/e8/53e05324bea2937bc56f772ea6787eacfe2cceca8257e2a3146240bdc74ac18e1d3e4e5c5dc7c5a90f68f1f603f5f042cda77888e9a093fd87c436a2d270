\n        loader: 'shader-loader',\n        options: {\n          glsl: {\n            chunkPath: resolve(\"/glsl/chunks\")\n          }\n        }\n      }\n\t]\n}\n```\n\nYou can now require your glsl files:\n``` javascript\nvar vertexShader = require(\"shader.vs\");\nvar fragmentShader = require(\"shader.fs\");\n```\n\nif you use $xxx in your shader its replace by the content of xxx.glsl, for example:\n\n``` glsl\nvoid main(void) {\n\t$snoise //replace by chunks/snoise.glsl\n}\n```\n\nLearn more about loaders & webpack:\nhttp://webpack.github.io/docs/loaders.html\n\n## License\nMIT (http://www.opensource.org/licenses/mit-license.php)\n","maintainers":[{"name":"makio64","email":"davronai@gmail.com"}],"time":{"modified":"2022-06-26T18:32:14.102Z","created":"2015-02-08T11:11:45.296Z","1.0.0":"2015-02-08T11:11:45.296Z","1.1.0":"2015-02-18T20:11:06.397Z","1.1.1":"2015-02-19T12:38:57.934Z","1.1.2":"2015-02-19T13:29:48.989Z","1.1.3":"2015-07-12T04:03:46.092Z","1.1.4":"2015-11-10T22:35:43.969Z","1.2.0":"2016-07-25T11:53:14.655Z","1.2.1":"2016-07-26T15:58:40.603Z","1.3.0":"2016-09-20T05:12:49.169Z","1.3.1":"2017-07-24T17:45:58.595Z"},"homepage":"https://github.com/Makio64/shader-loader","keywords":["glsl","webpack","loader","shader","chunks"],"repository":{"type":"git","url":"git+https://github.com/Makio64/shader-loader.git"},"author":{"name":"David Ronai @Makio64"},"bugs":{"url":"https://github.com/Makio64/shader-loader/issues"},"license":"MIT","readmeFilename":"README.md"}